# Template .env buat produksi -- copy jadi ".env" (atau ".env.production")
# di server, isi nilainya. JANGAN commit file yang udah keisi ke git.

# Kalau frontend & backend di-serve di domain yang sama lewat Nginx (lihat
# deploy/nginx.conf, path /api/ di-proxy ke Gunicorn), isi domain yang sama
# persis dengan yang diakses user -- request ke API jadi same-origin, gak
# perlu mikirin CORS di production sama sekali.
NEXT_PUBLIC_API_BASE_URL=https://yourdomain.com

# Login/register lewat Google -- kosongin kalau belum dipakai, tombolnya
# otomatis nggak muncul (lihat component/GoogleSignInButton.jsx). Harus sama
# persis dengan GOOGLE_CLIENT_ID di Backend/.env.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Kalau S3_ENDPOINT_URL di Backend/.env keisi (foto profil/CV di-upload ke
# object storage, bukan folder lokal), isi domain endpoint yang sama persis
# di sini -- dipakai buat izinin domain itu di CSP img-src, kalau nggak
# browser diem-diem nge-block <img> foto profil/avatar yang nunjuk ke sana.
# Kosongin kalau belum pakai S3 storage.
NEXT_PUBLIC_S3_PUBLIC_URL=
