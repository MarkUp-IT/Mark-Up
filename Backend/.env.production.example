# Template .env buat produksi -- copy jadi ".env" di server, isi semua nilainya.
# JANGAN commit file ".env" yang udah keisi ke git.

DEBUG=False
PRODUCTION=True
SECRET_KEY=
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Domain frontend -- dipakai buat CORS/CSRF trusted origin & link di email
# (verifikasi/reset password). Kalau frontend & backend di satu domain yang
# sama (lihat deploy/nginx.conf), isi domain yang sama persis.
FRONTEND_URL=https://yourdomain.com
FRONTEND_URL_ALT=https://www.yourdomain.com

DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# SMTP asli -- tanpa ini, verifikasi email & lupa password gak akan pernah
# beneran ke-kirim (lihat instruksi setup provider SMTP).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# Object storage S3-compatible (DomainEsia / R2 / provider S3-compatible
# lain) -- kosongin semua kalau belum aktif, otomatis fallback ke storage
# lokal (lihat settings.py, USE_S3_STORAGE). S3_ENDPOINT_URL diisi persis
# sesuai yang dikasih providernya (contoh format beda-beda tiap provider).
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION_NAME=auto

# Login/register lewat Google -- kosongin kalau belum dipakai, endpoint
# google-login/ otomatis balikin 503 tanpa ganggu fitur lain.
GOOGLE_CLIENT_ID=
